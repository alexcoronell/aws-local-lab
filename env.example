# =============================================================
# 🔐 AWS LOCAL ENVIRONMENT — Environment Variables
# ⚠️  For development only. DO NOT use in production.
# =============================================================

# --- AWS / LocalStack ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
LOCALSTACK_ENDPOINT=http://localhost:4566

# --- S3 / MinIO ---
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password123
MINIO_ENDPOINT=http://localhost:9000
S3_BUCKET_NAME=my-bucket

# --- DynamoDB ---
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_TABLE=UserLogs

# --- PostgreSQL / RDS ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=maindb
POSTGRES_USER=admin
POSTGRES_PASSWORD=password123
DATABASE_URL=postgresql://admin:password123@localhost:5432/maindb

# --- MySQL / RDS ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=maindb
MYSQL_USER=admin
MYSQL_PASSWORD=password123

# --- Redis / ElastiCache ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=password123
REDIS_URL=redis://:password123@localhost:6379

# --- SQS / ElasticMQ ---
SQS_ENDPOINT=http://localhost:9324
SQS_QUEUE_URL=http://localhost:9324/000000000000/user-onboarding-queue

# --- SES / Mailhog ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# --- OpenSearch ---
OPENSEARCH_ENDPOINT=http://localhost:9200
OPENSEARCH_INDEX=my-index

# --- Cognito / Keycloak ---
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=my-app
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=password123

# --- Kafka / Kinesis ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=user-events

# --- Secrets Manager / Vault ---
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root-token

# --- Step Functions ---
STEP_FUNCTION_NAME=UserOnboardingWorkflow
STEP_FUNCTION_ARN=arn:aws:states:us-east-1:000000000000:stateMachine:UserOnboardingWorkflow
